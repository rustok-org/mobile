{
  "$meta": {
    "product": "Rustok — Mission Control wallet",
    "version": "1.0.0-handoff",
    "stack": "React Native 0.85.2 + NativeWind",
    "sourceOfTruth": true,
    "notes": [
      "Two layers: `primitive` (raw palette) and `theme.<name>.semantic` (role → primitive).",
      "Components must consume SEMANTIC tokens only, never primitives directly.",
      "DARK is canonical for v1 and fully populated. LIGHT is STRUCTURE ONLY: every semantic key exists but resolves to null — fill values in a later pass.",
      "INVARIANT (from brief): `connection.*` (the agent/online 'wire', teal) and `risk.*` (allow/warn/block, green/amber/red) are DELIBERATELY SEPARATE channels. Never map a risk color onto a connection role or vice-versa. Connection status ≠ risk status.",
      "Sizing values are unitless dp (RN points). Colors are hex or rgba. letterSpacing is given in em — multiply by fontSize for RN's dp `letterSpacing`."
    ]
  },

  "primitive": {
    "ink": {
      "950": "#0A0C10",
      "900": "#0B0E12",
      "880": "#0C0F13",
      "850": "#0D1014",
      "820": "#0F1318",
      "800": "#12161B",
      "780": "#13171D",
      "720": "#161B22",
      "680": "#1C222A",
      "620": "#20262E",
      "560": "#232A33",
      "500": "#2A313B",
      "420": "#3A424D",
      "360": "#4F5864",
      "340": "#545C68",
      "300": "#586170",
      "260": "#6B7480",
      "220": "#8A93A0",
      "180": "#9AA3AF",
      "050": "#E7EBEF"
    },
    "teal": {
      "500": "#16E0C3",
      "ink": "#06120F"
    },
    "violet": {
      "700": "#7A45CC",
      "500": "#9D5CFF",
      "400": "#B27DFF"
    },
    "green": { "500": "#2FD27A" },
    "amber": { "500": "#FFB020" },
    "red":   { "500": "#FF4D4D", "300": "#FF8A8A" },
    "alphaWhite": {
      "03": "rgba(255,255,255,0.03)",
      "05": "rgba(255,255,255,0.05)",
      "06": "rgba(255,255,255,0.06)",
      "07": "rgba(255,255,255,0.07)",
      "10": "rgba(255,255,255,0.10)",
      "12": "rgba(255,255,255,0.12)"
    }
  },

  "theme": {
    "dark": {
      "semantic": {
        "canvas":         { "value": "#0A0C10", "ref": "ink.950", "role": "app background" },
        "navBar":         { "value": "#0B0E12", "ref": "ink.900", "role": "bottom tab bar bg" },
        "surface":        { "value": "#12161B", "ref": "ink.800", "role": "sheet / panel bg" },
        "surfaceRaised":  { "value": "#13171D", "ref": "ink.780", "role": "hero approval card bg (top of gradient)" },
        "surfaceInset":   { "value": "#0D1014", "ref": "ink.850", "role": "telemetry cell / recessed field" },
        "controlTrack":   { "value": "#0C0F13", "ref": "ink.880", "role": "arm-button track (disarmed)" },

        "borderSubtle":   { "value": "rgba(255,255,255,0.06)", "ref": "alphaWhite.06", "role": "hairline dividers" },
        "borderDefault":  { "value": "#232A33", "ref": "ink.560", "role": "field / chip borders" },
        "borderStrong":   { "value": "#2A313B", "ref": "ink.500", "role": "card / button borders" },
        "borderDisabled": { "value": "#3A424D", "ref": "ink.420", "role": "inactive icon stroke" },

        "textPrimary":    { "value": "#E7EBEF", "ref": "ink.050", "role": "headings, decoded action, values" },
        "textSecondary":  { "value": "#8A93A0", "ref": "ink.220", "role": "secondary labels, spender" },
        "textTertiary":   { "value": "#9AA3AF", "ref": "ink.180", "role": "finding body copy" },
        "textMuted":      { "value": "#586170", "ref": "ink.300", "role": "eyebrow labels, addresses, units" },
        "textOnAccent":   { "value": "#06120F", "ref": "teal.ink", "role": "text on teal fill" },

        "accent":         { "value": "#16E0C3", "ref": "teal.500", "role": "primary / system-go / active tab" },
        "accentInk":      { "value": "#06120F", "ref": "teal.ink", "role": "ink on accent" },

        "connectionOnline":  { "value": "#16E0C3", "ref": "teal.500", "role": "agent connected / online — WIRE channel" },
        "connectionOffline": { "value": "#586170", "ref": "ink.300", "role": "agent not connected — WIRE channel" },

        "armFrom":        { "value": "#7A45CC", "ref": "violet.700", "role": "hold-to-arm charge gradient START" },
        "armTo":          { "value": "#16E0C3", "ref": "teal.500",  "role": "hold-to-arm charge gradient END" },

        "riskAllowFg":     { "value": "#2FD27A", "ref": "green.500", "role": "ALLOW foreground" },
        "riskAllowBg":     { "value": "rgba(47,210,122,0.06)",  "role": "ALLOW tint bg" },
        "riskAllowBorder": { "value": "rgba(47,210,122,0.25)",  "role": "ALLOW border" },

        "riskWarnFg":      { "value": "#FFB020", "ref": "amber.500", "role": "WARN foreground" },
        "riskWarnBg":      { "value": "rgba(255,176,32,0.12)",  "role": "WARN tint bg" },
        "riskWarnBorder":  { "value": "rgba(255,176,32,0.40)",  "role": "WARN border" },

        "riskBlockFg":       { "value": "#FF4D4D", "ref": "red.500", "role": "BLOCK foreground" },
        "riskBlockFgStrong": { "value": "#FF8A8A", "ref": "red.300", "role": "BLOCK emphasis (∞, ВСЁ)" },
        "riskBlockBg":       { "value": "rgba(255,77,77,0.10)",  "role": "BLOCK tint bg" },
        "riskBlockBorder":   { "value": "rgba(255,77,77,0.45)",  "role": "BLOCK border" }
      }
    },

    "light": {
      "$status": "STRUCTURE ONLY — do not ship. Every key mirrors dark; fill in a later pass. Draft values explored in the design canvas (frame 16) for reference.",
      "semantic": {
        "canvas": null, "navBar": null, "surface": null, "surfaceRaised": null,
        "surfaceInset": null, "controlTrack": null,
        "borderSubtle": null, "borderDefault": null, "borderStrong": null, "borderDisabled": null,
        "textPrimary": null, "textSecondary": null, "textTertiary": null, "textMuted": null, "textOnAccent": null,
        "accent": null, "accentInk": null,
        "connectionOnline": null, "connectionOffline": null,
        "armFrom": null, "armTo": null,
        "riskAllowFg": null, "riskAllowBg": null, "riskAllowBorder": null,
        "riskWarnFg": null, "riskWarnBg": null, "riskWarnBorder": null,
        "riskBlockFg": null, "riskBlockFgStrong": null, "riskBlockBg": null, "riskBlockBorder": null
      }
    }
  },

  "font": {
    "family": {
      "ui":   { "value": "Archivo",       "role": "all UI text, headings, body" },
      "mono": { "value": "JetBrains Mono", "role": "data: addresses, amounts, hashes, labels, risk readout" }
    },
    "size": {
      "micro": 9, "tiny": 10, "xs": 11, "sm": 12, "base": 13,
      "md": 14, "lg": 18, "xl": 22, "action": 23, "display": 26
    },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 },
    "tracking": {
      "$unit": "em — RN letterSpacing is dp; compute em * fontSize at use site",
      "tight": -0.01, "normal": 0, "label": 0.1, "labelWide": 0.16, "eyebrow": 0.22
    },
    "lineHeight": { "$unit": "multiplier", "tight": 1.2, "snug": 1.35, "body": 1.45, "relaxed": 1.6 }
  },

  "radius": {
    "chip": 8, "badge": 8, "cell": 11, "field": 12, "control": 15, "controlSm": 14,
    "card": 22, "pill": 20,
    "device": 38
  },

  "space": {
    "$scale": "dp",
    "1": 2, "2": 4, "3": 6, "4": 8, "5": 10, "6": 12, "7": 14, "8": 16, "9": 18, "10": 20, "11": 22, "12": 24
  },

  "size": {
    "armButtonHeight": 62,
    "hitTargetMin": 44,
    "tabIconBox": 20,
    "statusDot": 7,
    "screenWidth": 393,
    "screenHeight": 838
  },

  "elevation": {
    "$note": "RN: map to shadowColor/shadowOpacity/shadowRadius/elevation. Values are design intent.",
    "card":   { "y": 14, "blur": 40, "color": "rgba(0,0,0,0.40)" },
    "sheet":  { "y": -20, "blur": 50, "color": "rgba(0,0,0,0.50)" },
    "device": { "y": 30, "blur": 80, "color": "rgba(0,0,0,0.50)" }
  },

  "glow": {
    "$note": "teal glow used on active tab icon + armed button + online dot. RN: shadow on the element with shadowColor accent.",
    "accentSoft": { "blur": 6, "color": "rgba(22,224,195,0.50)" },
    "accentDot":  { "blur": 8, "color": "#16E0C3" },
    "armedInner": { "blur": 22, "color": "rgba(22,224,195,0.35)" }
  }
}
